{
  "version": 1,
  "defaultProfile": "default",
  "profiles": {
    "default": {
      "commands": {
        "build": "npm run build",
        "lint": "npm run lint",
        "test": "npx vitest run --reporter=dot --testTimeout=30000"
      },
      "services": [
        "scale-engine"
      ]
    },
    "productSmoke": {
      "commands": {
        "smoke": "powershell -ExecutionPolicy Bypass -File scripts/qa/product-smoke.ps1"
      },
      "services": [
        "scale-engine"
      ]
    }
  },
  "services": [
    {
      "name": "scale-engine",
      "path": ".",
      "type": "node",
      "required": true
    }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tmp",
    "temp",
    "coverage",
    "test-results"
  ],
  "policy": {
    "mode": "standard",
    "optionalToolsWarnOnly": true,
    "artifactGate": "warn",
    "artifactGateLevels": [
      "M",
      "L",
      "CRITICAL"
    ],
    "engineeringStandardsGate": "block",
    "productSmokeGate": "warn"
  }
}
